# Vercel Environment Variables
# Add these to your Vercel project settings

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Database (REQUIRED for Vercel)
# Use a managed database service like:
# - Vercel Postgres: postgresql://user:password@host/dbname
# - Supabase: postgresql://user:password@host/dbname
# - Railway: postgresql://user:password@host/dbname
# - PlanetScale MySQL: mysql+pymysql://user:password@host/dbname
DATABASE_URL=your-database-url-here

# Optional: External Services
OPENWEATHER_API_KEY=your-openweather-api-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE=+1234567890

# MQTT Configuration (optional - for local IoT)
MQTT_BROKER=localhost
MQTT_PORT=1883
